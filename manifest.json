{
  "manifest_version": 3,
  "name": "AI Web Translator",
  "version": "1.2.0",
  "description": "AI-powered webpage translation with DeepSeek/OpenRouter/OpenAI. Select text or translate entire pages.",
  "permissions": ["storage", "contextMenus"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "css": ["style.css"],
    "run_at": "document_end",
    "all_frames": false
  }],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Translator"
  },
  "commands": {
    "translate-page": {
      "suggested_key": { "default": "Ctrl+Shift+T" },
      "description": "Translate entire page"
    },
    "restore-page": {
      "suggested_key": { "default": "Ctrl+Shift+R" },
      "description": "Restore original text"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
